/* pages/analysis/analysis.wxss */
.container { padding: 16px 14px 100px; }
.bottom-space { height: 20px; }

/* 统计摘要 */
.summary-row { display: flex; gap: 10px; margin-bottom: 14px; }
.sum-item {
  font-size: 12px; padding: 5px 12px; border-radius: 10px;
  background: #FFFCF6; border: none; color: #717C73;
  box-shadow: 0 1px 3px rgba(113,124,115,.05);
}

/* 成员筛选 */
.member-tabs { display: flex; gap: 6px; white-space: nowrap; margin-bottom: 14px; }
.mtab {
  font-size: 12px; padding: 6px 14px; border-radius: 16px;
  background: #FFFCF6; border: none; color: #717C73;
  display: inline-block; flex-shrink: 0;
  box-shadow: 0 1px 2px rgba(113,124,115,.04);
  transition: all .2s ease;
}
.mtab.active {
  color: #9B7A45;
  background: rgba(155,122,69,.06);
  box-shadow: 0 2px 8px rgba(155,122,69,.1);
}

/* 空状态：卷轴+对勾 */
.empty-state { text-align: center; padding: 50px 16px; }
.empty-illustration { width: 90px; height: 72px; margin: 0 auto 20px; position: relative; }

/* 左轴 */
.ei-scroll-left {
  position: absolute; left: 4px; top: 18px;
  width: 10px; height: 36px;
  background: linear-gradient(90deg, rgba(142,107,62,.12), rgba(142,107,62,.04));
  border-radius: 6px;
  box-shadow: inset 0 0 4px rgba(142,107,62,.06);
}

/* 右轴 */
.ei-scroll-right {
  position: absolute; right: 4px; top: 18px;
  width: 10px; height: 36px;
  background: linear-gradient(270deg, rgba(142,107,62,.12), rgba(142,107,62,.04));
  border-radius: 6px;
  box-shadow: inset 0 0 4px rgba(142,107,62,.06);
}

/* 展开的纸 */
@keyframes scrollBreathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02, 1.01); }
}
.ei-scroll-paper {
  position: absolute; left: 12px; right: 12px; top: 16px; bottom: 16px;
  background: linear-gradient(180deg, var(--card) 0%, var(--bg-warm) 100%);
  border-radius: 4px;
  box-shadow: var(--shadow-1);
  animation: scrollBreathe 5s ease-in-out infinite;
}
.ei-scroll-paper::after {
  content: ''; position: absolute;
  left: 0; right: 0; top: 0; bottom: 0;
  background-image:
    repeating-linear-gradient(0deg,
      transparent, transparent 4px,
      rgba(142,107,62,.04) 4px, rgba(142,107,62,.04) 5px
    );
  border-radius: 4px;
}

/* 对勾 */
.ei-scroll-check {
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%,-55%) rotate(42deg);
  width: 8px; height: 18px;
  border-right: 2.5px solid var(--green);
  border-bottom: 2.5px solid var(--green);
  border-radius: 2px;
  z-index: 1;
}

/* 丝带 */
.ei-ribbon {
  position: absolute; left: 50%; top: 4px;
  transform: translateX(-50%);
  width: 30px; height: 5px;
  background: rgba(192,107,96,.15);
  border-radius: 1px;
  z-index: 2;
}
.ei-ribbon::before {
  content: '';
  position: absolute; left: 0; top: 5px;
  width: 0; height: 0;
  border-left: 3px solid transparent;
  border-right: 11px solid rgba(192,107,96,.08);
  border-top: 6px solid rgba(192,107,96,.08);
}
.ei-ribbon::after {
  content: '';
  position: absolute; right: 0; top: 5px;
  width: 0; height: 0;
  border-right: 3px solid transparent;
  border-left: 11px solid rgba(192,107,96,.08);
  border-top: 6px solid rgba(192,107,96,.08);
}

/* 火漆印章 */
.ei-seal {
  position: absolute; left: 50%; top: 7px;
  transform: translateX(-50%);
  width: 12px; height: 12px;
  background: rgba(192,107,96,.16);
  border-radius: 50%;
  z-index: 3;
  box-shadow: 0 0 0 1px rgba(192,107,96,.06);
}
.ei-seal::after {
  content: '·'; position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 8px; color: rgba(192,107,96,.25);
}

/* 氛围粒子 */
.ei-particle {
  position: absolute; width: 3px; height: 3px;
  background: rgba(90,138,110,.16);
  border-radius: 50%;
  animation: floatUp 3.2s ease-in-out infinite;
}
.ei-particle.p1 { left: 0; top: 20px; animation-delay: 0s; width: 2px; height: 2px; }
.ei-particle.p2 { right: 2px; top: 36px; animation-delay: .9s; }
.ei-particle.p3 { left: 4px; bottom: 6px; animation-delay: 1.8s; }
@keyframes floatUp {
  0%, 100% { transform: translateY(0); opacity: .35; }
  50% { transform: translateY(-8px); opacity: .8; }
}

.empty-text { font-size: 16px; font-weight: 600; color: var(--text-primary); display: block; margin-top: 4px; }
.empty-hint { font-size: 12px; color: var(--text-light); display: block; margin-top: 6px; line-height: 1.5; }

/* 安心清单项 */
.gap-item {
  background: #FFFCF6; border-radius: 14px; padding: 16px; margin-bottom: 10px;
  border: none;
  box-shadow: 0 1px 3px rgba(113,124,115,.05), 0 2px 8px rgba(113,124,115,.03);
}
.gap-item.p1 { box-shadow: 0 1px 3px rgba(155,122,69,.05); }
.gi-header { display: flex; align-items: flex-start; gap: 10px; }
.gi-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
.gi-dot.red { background: #B95F57; box-shadow: 0 0 6px rgba(185,95,87,.25); }
.gi-dot.gold { background: #9B7A45; box-shadow: 0 0 6px rgba(155,122,69,.2); }
.gi-info { flex: 1; min-width: 0; }
.gi-member { font-size: 11px; color: #969D92; display: block; }
.gi-title { font-size: 14px; font-weight: 600; color: #29302B; display: block; margin-top: 2px; }
.gi-priority {
  font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 6px;
  color: #9B7A45; background: rgba(155,122,69,.08); white-space: nowrap;
}
.gi-priority.red { color: #B95F57; background: rgba(185,95,87,.06); }
.gi-desc { font-size: 12px; color: #717C73; display: block; margin-top: 8px; line-height: 1.5; }

/* 类目说明 */
.gi-category { margin-top: 10px; padding: 12px; border-radius: 12px; background: #F8F4EC; }
.gic-label { font-size: 11px; font-weight: 700; color: #9B7A45; display: block; }
.gic-text { font-size: 12px; color: #48534B; line-height: 1.5; display: block; margin-top: 4px; }

/* 缺口内容 */
.gi-content-missing {
  margin-top: 10px; padding: 12px; border-radius: 12px;
  background: rgba(82,127,150,.04);
}
.gicm-title { font-size: 11px; font-weight: 600; color: #527F96; display: block; margin-bottom: 8px; }
.gicm-list { display: flex; flex-direction: column; gap: 5px; }
.gicm-item { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
.gicm-label { font-size: 11px; color: #48534B; }
.gicm-hint { font-size: 10px; color: #969D92; text-align: right; }
.gicm-more { font-size: 10px; color: #527F96; margin-top: 6px; display: block; }

/* 无匹配类目 */
.gi-no-match { margin-top: 10px; padding: 12px; border-radius: 12px; background: #F8F4EC; }
.gnm-title { font-size: 11px; font-weight: 600; color: #717C73; display: block; margin-bottom: 8px; }
.gnm-list { display: flex; flex-direction: column; gap: 4px; }
.gnm-item { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
.gnm-label { font-size: 11px; color: #48534B; }
.gnm-hint { font-size: 10px; color: #969D92; text-align: right; }

/* 参考样例 */
.gi-samples { margin-top: 10px; }
.gs-toggle {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 0; border-top: 1px solid #E1D7C7;
  font-size: 12px; color: #527F96;
}
.gs-arrow { font-size: 16px; transition: transform .2s ease; }
.gs-arrow.up { transform: rotate(90deg); }
.gs-list { margin-top: 6px; display: flex; flex-direction: column; gap: 6px; }
.gs-card {
  background: #F8F4EC; border-radius: 12px; padding: 12px 14px;
  box-shadow: 0 1px 3px rgba(113,124,115,.03);
}
.gsc-top { display: flex; justify-content: space-between; align-items: center; }
.gsc-name { font-size: 12px; font-weight: 600; color: #29302B; }
.gsc-price { font-size: 12px; font-weight: 600; color: #9B7A45; }
.gsc-source { font-size: 10px; color: #969D92; display: block; margin-top: 3px; }
.gsc-items { margin-top: 10px; display: flex; flex-direction: column; gap: 4px; }
.gsc-item { display: flex; gap: 6px; }
.gsi-dot { font-size: 10px; color: #969D92; min-width: 10px; }
.gsi-text { font-size: 11px; color: #717C73; line-height: 1.5; }
.gsc-note {
  font-size: 10px; color: #969D92; margin-top: 8px; padding-top: 8px;
  border-top: 1px solid rgba(225,215,199,.5); line-height: 1.5;
}
.gsc-actions { margin-top: 8px; display: flex; justify-content: flex-end; }
.gsc-detail { font-size: 11px; color: #527F96; padding: 4px 0; }
.gsc-level-tag {
  font-size: 9px; padding: 1px 5px; border-radius: 4px; margin-right: 6px;
  display: inline-block;
}
.gs-card.basic .gsc-level-tag { background: rgba(82,127,150,.10); color: #527F96; }
.gs-card.complete .gsc-level-tag { background: rgba(155,122,69,.10); color: #9B7A45; }
.gsc-use { font-size: 10px; color: #969D92; margin-top: 6px; display: block; font-style: italic; }

/* 更多 */
.show-more { text-align: center; padding: 14px 0; }
.show-more text { font-size: 12px; color: #969D92; }

/* ===== 全部完善奖章 ===== */
.all-clear-badge {
  width: 40px; height: 44px; margin: 0 auto 10px; position: relative;
}
.acb-circle {
  width: 32px; height: 32px; border-radius: 50%; margin: 0 auto;
  background: linear-gradient(135deg, rgba(90,138,110,.12), rgba(90,138,110,.04));
  border: 2px solid rgba(90,138,110,.16);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; color: var(--green);
  box-shadow: 0 2px 8px rgba(90,138,110,.08);
}
.acb-ribbon {
  position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 16px; height: 10px;
  background: rgba(90,138,110,.12);
  clip-path: polygon(0 0, 50% 100%, 100% 0, 75% 0, 50% 40%, 25% 0);
}

/* ===== 深色主题覆盖 ===== */
.theme-dark .sum-item { background: var(--card); color: var(--text-muted); box-shadow: var(--shadow-1); }
.theme-dark .mtab { background: var(--card); color: var(--text-muted); box-shadow: var(--shadow-1); }
.theme-dark .mtab.active { color: var(--gold); background: var(--gold-bg); box-shadow: 0 2px 8px rgba(184,151,106,.12); }
.theme-dark .gap-item { background: var(--card); box-shadow: var(--shadow-1); }
.theme-dark .gi-category { background: var(--bg-warm); }
.theme-dark .gi-no-match { background: var(--bg-warm); }
.theme-dark .gi-content-missing { background: var(--blue-bg); }
.theme-dark .gicm-title { color: var(--blue); }
.theme-dark .gs-card { background: var(--bg-warm); }
.theme-dark .gs-toggle { border-top-color: var(--border); }
.theme-dark .gsc-note { border-top-color: var(--border-soft); }
.theme-dark .gs-card.basic .gsc-level-tag { background: var(--blue-bg); color: var(--blue); }
.theme-dark .gs-card.complete .gsc-level-tag { background: var(--gold-bg); color: var(--gold); }


/* pages/member-form/member-form.wxss */
.container { padding: 16px; padding-bottom: 80px; }

/* 装饰插画 */
.mf-illustration { text-align: center; margin-bottom: 16px; position: relative; }
.mfi-circle {
  width: 52px; height: 52px; border-radius: 50%; margin: 0 auto;
  background: linear-gradient(135deg, rgba(155,122,69,.1), rgba(155,122,69,.03));
  box-shadow: 0 2px 12px rgba(155,122,69,.06);
  display: flex; align-items: center; justify-content: center;
}
.mfi-circle.pet {
  background: linear-gradient(135deg, rgba(82,127,104,.1), rgba(82,127,104,.03));
  box-shadow: 0 2px 12px rgba(82,127,104,.06);
}
.mfi-icon { font-size: 22px; }
.mfi-plus {
  position: absolute; right: calc(50% - 34px); bottom: 4px;
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--gold);
  box-shadow: 0 1px 4px rgba(142,107,62,.18);
  display: flex; align-items: center; justify-content: center;
}
.mfi-plus::before, .mfi-plus::after {
  content: ''; position: absolute; background: #FFFCF7; border-radius: 1px;
}
.mfi-plus::before { width: 8px; height: 1.5px; }
.mfi-plus::after { width: 1.5px; height: 8px; }

/* 档案类型选择 */
.kind-banner {
  background: linear-gradient(135deg, rgba(155,122,69,.08), rgba(155,122,69,.02));
  border-radius: 14px; padding: 14px; margin-bottom: 14px; border: none;
  box-shadow: 0 1px 3px rgba(155,122,69,.05);
}
.kind-banner.pet {
  background: linear-gradient(135deg, rgba(82,127,104,.06), rgba(82,127,150,.02));
  box-shadow: 0 1px 3px rgba(82,127,104,.05);
}
.kind-title { display: block; font-size: 16px; font-weight: 700; color: #9B7A45; }
.kind-banner.pet .kind-title { color: #527F68; }
.kind-desc { display: block; font-size: 11px; color: #717C73; margin-top: 2px; }

/* 智能录入 */
.smart-box {
  background: rgba(82,127,150,.03); border-radius: 14px;
  padding: 14px; margin-bottom: 16px; border: none;
}
.smart-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
.smart-title { font-size: 14px; font-weight: 600; color: #527F96; }
.smart-hint { font-size: 10px; color: #969D92; }
.smart-textarea {
  width: 100%; min-height: 90px; max-height: 140px;
  background: #FFFCF6; color: #48534B; border: 1px solid #E1D7C7;
  border-radius: 10px; padding: 10px 12px; font-size: 13px;
  line-height: 1.6; box-sizing: border-box;
}
.smart-btn {
  width: 100%; margin-top: 8px; padding: 8px 0; border-radius: 10px;
  background: rgba(82,127,150,.12); color: #527F96;
  font-size: 13px; font-weight: 600; border: none;
  transition: transform .15s ease;
}
.smart-btn::after { border: none; }
.smart-btn:active { transform: scale(.97); }

/* 表单字段 */
.form-group { margin-top: 14px; }
.label { display: block; font-size: 12px; font-weight: 600; color: #717C73; margin-bottom: 6px; }
.input {
  width: 100%; padding: 10px 12px; background: #FFFCF6;
  border: 1px solid #E1D7C7; border-radius: 10px; color: #48534B;
  font-size: 14px; box-sizing: border-box;
  box-shadow: 0 1px 2px rgba(113,124,115,.03);
}
.textarea {
  width: 100%; min-height: 80px; padding: 10px 12px;
  background: #FFFCF6; border: 1px solid #E1D7C7;
  border-radius: 10px; color: #48534B; font-size: 14px;
  box-sizing: border-box; line-height: 1.6;
}
.picker {
  padding: 10px 12px; background: #FFFCF6; border: 1px solid #E1D7C7;
  border-radius: 10px; color: #48534B; font-size: 14px;
}
.form-row { display: flex; gap: 10px; }
.form-group.half { flex: 1; }

/* 保存 */
.save-btn {
  width: 100%; margin-top: 20px; padding: 14px; border-radius: 14px;
  background: #9B7A45; color: #F8F4EC; font-weight: 700; font-size: 16px;
  border: none; box-sizing: border-box;
  box-shadow: 0 2px 8px rgba(155,122,69,.2);
  transition: transform .15s ease;
}
.save-btn::after { border: none; }
.save-btn:active { transform: scale(.97); }

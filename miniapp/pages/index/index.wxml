<!--pages/index/index.wxml - 安心总览（时间轴版）-->
<view class="container page-enter {{ pageThemeClass }}">
  <!-- 隐私弹窗 -->
  <view class="privacy-modal" wx:if="{{ !privacyAccepted }}">
    <view class="privacy-content card-elevated">
      <text class="privacy-title">安心家册</text>
      <view class="privacy-items">
        <text class="pi-text">数据默认保存在本机，不会自动上传。</text>
        <text class="pi-text">云备份、图片识别等功能需要你主动使用。</text>
        <text class="pi-text">本工具仅做资料整理与到期提醒。</text>
      </view>
      <button class="btn btn-gold" bindtap="onAcceptPrivacy">同意并开始使用</button>
      <text class="privacy-link" bindtap="onFullPrivacy">查看完整声明</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state entrance-item entrance-1" wx:if="{{ stats.members === 0 }}">
    <view class="empty-illustration">
      <view class="ei-book-left"></view>
      <view class="ei-book-right"></view>
      <view class="ei-book-spine"></view>
      <view class="ei-pen"></view>
      <view class="ei-ink"></view>
      <view class="ei-bookmark"></view>
      <view class="ei-particle p1"></view>
      <view class="ei-particle p2"></view>
      <view class="ei-particle p3"></view>
      <view class="ei-particle p4"></view>
    </view>
    <text class="empty-title">开始搭建你的家庭安心家册</text>
    <text class="empty-desc">添加家人、宠物和重要资料，我们会帮你留意到期和待完善的事项</text>
    <button class="btn btn-gold" bindtap="onAddMember">添加第一位家人</button>
    <text class="empty-later" bindtap="onAddPet">稍后添加宠物</text>
  </view>

  <block wx:else>
    <!-- 骨架屏 -->
    <view wx:if="{{ loading }}">
      <view class="skeleton skeleton-title" style="margin:8px 0 16px;"></view>
      <view class="skeleton skeleton-card" style="margin-bottom:14px;"></view>
      <view style="display:flex;gap:8px;margin-bottom:18px;">
        <view class="skeleton" style="flex:1;height:64px;border-radius:14px;"></view>
        <view class="skeleton" style="flex:1;height:64px;border-radius:14px;"></view>
        <view class="skeleton" style="flex:1;height:64px;border-radius:14px;"></view>
      </view>
      <view class="skeleton" style="height:60px;margin-bottom:14px;border-radius:14px;"></view>
      <view class="skeleton skeleton-card"></view>
      <view class="skeleton skeleton-card"></view>
      <view class="skeleton skeleton-card" style="height:60px;"></view>
    </view>

    <!-- 实际内容 -->
    <view wx:else>
    <!-- 时段问候 -->
    <view class="greeting-block entrance-item entrance-1">
      <view class="gr-wave-wrap"><text class="gr-wave">{{ greetingEmoji }}</text></view>
      <view class="gr-text">
        <text class="gr-greeting">{{ greeting }}</text>
        <text class="gr-date">{{ todayDate }}</text>
      </view>
    </view>

    <!-- 家庭状态 + 概况 -->
    <view class="status-header entrance-item entrance-2">
      <view class="sh-left">
        <text class="sh-name">{{ familyName }}的安心家册</text>
        <text class="sh-family" wx:if="{{ attentionCount > 0 }}">今天有 {{ attentionCount }} 件事需要留意</text>
        <text class="sh-family" wx:else>一切安好</text>
      </view>
      <text class="sh-edit" bindtap="onEditFamily" bindlongpress="onLongPressSetting">设置</text>
    </view>

    <!-- 家庭概况条 -->
    <view class="overview-strip page-curl entrance-item entrance-3">
      <view class="ovs-item"><text class="ovs-num num-tabular count-animate">{{ animatedStats.members }}</text><text class="ovs-lbl">家人</text></view>
      <view class="ovs-item"><text class="ovs-num num-tabular count-animate">{{ animatedStats.pets }}</text><text class="ovs-lbl">宠物</text></view>
      <view class="ovs-item"><text class="ovs-num num-tabular count-animate">{{ animatedStats.policies }}</text><text class="ovs-lbl">资料</text></view>
      <view class="ovs-item"><text class="ovs-num num-tabular count-animate {{ animatedStats.gaps > 0 ? 'warn' : '' }}">{{ animatedStats.gaps }}</text><text class="ovs-lbl">待完善</text></view>
    </view>

    <!-- 主动入口 -->
    <view class="main-actions entrance-item entrance-4">
      <view class="ma-btn" bindtap="onAddMember"><text class="ma-icon">👤</text><text class="ma-label">添加家人</text></view>
      <view class="ma-btn" bindtap="onAddPet"><text class="ma-icon">🐾</text><text class="ma-label">添加宠物</text></view>
      <view class="ma-btn" bindtap="onAddRecord"><text class="ma-icon">📋</text><text class="ma-label">添加资料</text></view>
    </view>

    <!-- ===== 时间轴 ===== -->
    <view class="timeline entrance-item entrance-5" wx:if="{{ timelineItems.length > 0 }}">
      <text class="tl-section-title">近期提醒</text>
      <view class="tl-item entrance-item entrance-{{ 5 + index }}" wx:for="{{ timelineItems }}" wx:key="key" wx:if="{{ index < 8 }}">
        <view class="tl-dot {{ item.urgent ? 'urgent' : item.expired ? 'urgent' : item.priority === 0 ? 'normal' : 'muted' }} {{ item.expired ? 'pulse-dot' : '' }}"></view>
        <view class="tl-card page-curl {{ item.expired ? 'urgent has-clip' : item.urgent ? 'urgent has-clip' : '' }}" bindtap="onTapAlert" data-type="{{ item.dataType }}" data-member-id="{{ item.memberId }}">
          <view class="paperclip {{ item.expired ? 'red' : item.urgent ? 'gold' : 'muted' }}" wx:if="{{ item.expired || item.urgent }}"></view>
          <view class="tlc-top">
            <text class="tlc-title">{{ item.title }}</text>
            <text class="tlc-tag {{ item.expired ? 'urgent' : item.urgent ? 'normal' : 'muted' }}">{{ item.tag }}</text>
          </view>
          <text class="tlc-desc">{{ item.desc }}</text>
        </view>
      </view>
      <view class="tl-footer" wx:if="{{ timelineItems.length > 8 }}" bindtap="onViewAll">
        <text>查看全部 {{ timelineItems.length }} 条提醒 ›</text>
      </view>
    </view>

    <!-- 无提醒 -->
    <view class="tl-clear entrance-item entrance-5" wx:if="{{ timelineItems.length === 0 }}">
      <text>暂无待提醒事项，一切安心 ✓</text>
    </view>

    <!-- 页脚 -->
    <view class="page-footer">· 1 ·</view>

    <!-- 演示提示 -->
    <view class="demo-tip" wx:if="{{ isDemo }}">
      <text>演示数据 · 可自由修改</text>
      <text class="demo-reset" bindtap="onLoadDemo">重置</text>
    </view>
    </view>
  </block>

  <view class="bottom-space"></view>
</view>
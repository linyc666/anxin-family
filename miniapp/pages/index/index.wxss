/* pages/index/index.wxss — 时间轴版 */
.container { padding: 20px 16px 100px; }
.bottom-space { height: 20px; }

/* ===== 时段问候 ===== */
.greeting-block {
  display: flex; align-items: center; gap: 12px;
  padding: 8px 0 16px; margin-bottom: 4px;
}
.gr-wave { font-size: 30px; line-height: 1; }
.gr-text { display: flex; flex-direction: column; }
.gr-greeting { font-size: 21px; font-weight: 700; color: var(--text-primary); letter-spacing: .3px; }
.gr-date { font-size: 11px; color: var(--text-light); margin-top: 3px; }

/* ===== 隐私弹窗 ===== */
.privacy-modal {
  position: fixed; inset: 0; background: rgba(0,0,0,.5);
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  z-index: 999; display: flex; align-items: center; justify-content: center; padding: 20px;
}
.privacy-content { padding: 28px 24px; max-width: 340px; width: 100%; text-align: center; }
.privacy-title { font-size: 22px; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 18px; }
.pi-text { font-size: 13px; color: var(--text-muted); display: block; padding: 6px 0; line-height: 1.6; }
.privacy-link { font-size: 11px; color: var(--text-light); display: block; margin-top: 14px; }

/* ===== 空状态 ===== */
.empty-state { text-align: center; padding: 70px 20px 40px; }
.empty-illustration { margin-bottom: 24px; }
.ei-house {
  width: 56px; height: 52px; margin: 0 auto; position: relative;
  color: var(--gold);
}
.ei-house::before {
  content: ''; position: absolute;
  width: 0; height: 0;
  border-left: 28px solid transparent;
  border-right: 28px solid transparent;
  border-bottom: 22px solid var(--gold);
  top: 0; left: 0; opacity: .25;
}
.ei-house::after {
  content: ''; position: absolute;
  width: 32px; height: 28px;
  background: var(--gold);
  border-radius: 3px 3px 0 0;
  bottom: 0; left: 50%; transform: translateX(-50%);
  opacity: .18;
}
.empty-title { font-size: 19px; font-weight: 700; color: var(--text-primary); display: block; }
.empty-desc { font-size: 13px; color: var(--text-light); display: block; margin-top: 10px; line-height: 1.5; }
.empty-later { font-size: 12px; color: var(--text-light); display: block; margin-top: 14px; }

/* ===== 家庭状态头 ===== */
.status-header { margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center; }
.sh-left { display: flex; flex-direction: column; }
.sh-name { font-size: 16px; font-weight: 600; color: var(--text-muted); }
.sh-family { font-size: 11px; color: var(--text-light); margin-top: 2px; }
.sh-edit {
  font-size: 11px; color: var(--gold); padding: 3px 12px;
  background: var(--gold-bg); border-radius: 10px; border: none;
  transition: background var(--ease-out);
}
.sh-edit:active { background: var(--gold-bg-hover); }

/* ===== 家庭概况条 ===== */
.overview-strip {
  display: flex; margin-bottom: 18px; border-radius: var(--radius);
  background: var(--card); box-shadow: var(--shadow-1);
  overflow: hidden;
}
.ovs-item {
  flex: 1; text-align: center; padding: 12px 4px;
  border-right: 1px solid var(--border-soft);
}
.ovs-item:last-child { border-right: none; }
.ovs-num { font-size: 20px; font-weight: 700; color: var(--text-primary); display: block; }
.ovs-num.warn { color: var(--gold); }
.ovs-lbl { font-size: 10px; color: var(--text-light); display: block; margin-top: 2px; }

/* ===== 三个主动入口 ===== */
.main-actions { display: flex; gap: 8px; margin-bottom: 22px; }
.ma-btn {
  flex: 1; height: 68px; border-radius: var(--radius);
  background: var(--card); box-shadow: var(--shadow-1);
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; border: none; gap: 5px;
  transition: transform var(--ease-out), box-shadow var(--ease-out);
}
.ma-btn:active { transform: scale(.97); box-shadow: 0 0 2px rgba(74,80,73,.02); }
.ma-icon { font-size: 20px; line-height: 1; }
.ma-label { font-size: 10px; color: var(--text-muted); }

/* ===== 时间轴 ===== */
.timeline { position: relative; padding-left: 24px; }

/* 竖线 */
.timeline::before {
  content: ''; position: absolute; left: 7px; top: 4px; bottom: 4px;
  width: 1.5px;
  background: linear-gradient(
    to bottom,
    var(--gold-border),
    var(--border-soft) 30%,
    var(--border-soft) 70%,
    transparent
  );
  border-radius: 1px;
}

.tl-section-title {
  font-size: 11px; font-weight: 600; color: var(--text-light);
  margin-bottom: 8px; letter-spacing: .5px;
}

.tl-item { position: relative; margin-bottom: 12px; }

/* 节点圆点 */
.tl-dot {
  position: absolute; left: -20px; top: 16px;
  width: 10px; height: 10px; border-radius: 50%;
  z-index: 1;
}
.tl-dot.urgent {
  background: var(--red);
  box-shadow: 0 0 0 3px rgba(192,107,96,.15);
}
.tl-dot.normal {
  background: var(--gold);
  box-shadow: 0 0 0 3px rgba(142,107,62,.1);
}
.tl-dot.muted {
  background: var(--text-light);
  box-shadow: 0 0 0 3px rgba(153,162,151,.1);
}

/* 时间轴卡片 */
.tl-card {
  background: var(--card); border-radius: var(--radius);
  padding: 14px 16px; box-shadow: var(--shadow-1);
  transition: transform var(--ease-out), box-shadow var(--ease-out);
}
.tl-card:active { transform: scale(.985); box-shadow: 0 0 2px rgba(74,80,73,.02); }
.tl-card.urgent {
  box-shadow: 0 1px 4px rgba(192,107,96,.06), 0 2px 8px rgba(192,107,96,.04);
}
.tlc-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
.tlc-title {
  font-size: 14px; font-weight: 600; color: var(--text-primary);
  display: block; flex: 1; line-height: 1.4;
}
.tlc-tag {
  font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 6px;
  white-space: nowrap; flex-shrink: 0;
}
.tlc-tag.urgent { color: var(--red); background: var(--red-bg); }
.tlc-tag.normal { color: var(--gold); background: var(--gold-bg); }
.tlc-tag.muted { color: var(--text-muted); background: rgba(115,124,114,.06); }
.tlc-desc { font-size: 11px; color: var(--text-light); display: block; margin-top: 5px; }

/* 时间轴底部 */
.tl-footer { text-align: center; padding: 10px 0 0; }
.tl-footer text { font-size: 12px; color: var(--text-light); }

/* 无提醒状态 */
.tl-clear {
  text-align: center; padding: 20px 0;
  color: var(--text-light); font-size: 13px;
}

/* ===== 演示提示 ===== */
.demo-tip {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 11px; color: var(--text-light); padding: 10px 0;
}
.demo-reset { color: var(--gold); }

/* ===== 按钮 ===== */
.btn {
  padding: 12px 28px; border-radius: 12px; border: none;
  background: var(--bg-warm); color: var(--text-body); font-size: 14px;
  box-shadow: 0 1px 2px rgba(74,80,73,.03);
}
.btn-gold {
  background: var(--gold); color: #FFFCF7; font-weight: 600;
  box-shadow: var(--shadow-btn);
}

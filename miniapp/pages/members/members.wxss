/* pages/members/members.wxss */
.container { padding: 16px 14px 90px; }
.bottom-space { height: 20px; }

/* ===== 家人/宠物切换 ===== */
.folder-tabs { display: flex; gap: 10px; margin-bottom: 16px; }
.ftab {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 6px;
  padding: 10px 0; border-radius: 14px; font-size: 15px; font-weight: 600;
  background: var(--card); border: none; color: var(--text-muted);
  box-shadow: 0 1px 3px rgba(74,80,73,.04);
  transition: all var(--ease-out);
}
.ftab.active {
  color: var(--gold);
  background: var(--gold-bg);
  box-shadow: 0 2px 8px rgba(142,107,62,.08);
}
.ftab-count {
  font-size: 12px; background: rgba(113,124,115,.06);
  padding: 1px 8px; border-radius: 8px;
}

/* ===== 档案夹卡片 ===== */
.folder-card {
  background: #FFFCF6; border-radius: 14px; padding: 16px;
  margin-bottom: 10px; border: none;
  box-shadow: 0 1px 3px rgba(113,124,115,.05), 0 2px 8px rgba(113,124,115,.03);
  transition: box-shadow .2s ease;
}
.fc-header { display: flex; align-items: center; gap: 10px; }
.fc-avatar {
  width: 40px; height: 40px; border-radius: 20px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; flex-shrink: 0;
  background: linear-gradient(135deg, rgba(155,122,69,.12), rgba(155,122,69,.04));
  color: #9B7A45;
  box-shadow: 0 2px 6px rgba(155,122,69,.08);
}
.fc-person-icon { font-size: 16px; }
.fc-avatar.pet {
  background: linear-gradient(135deg, rgba(82,127,104,.12), rgba(82,127,104,.04));
  color: #527F68;
  box-shadow: 0 2px 6px rgba(82,127,104,.08);
}

/* CSS 宠物小头像 */
.fc-pet-icon { position: relative; width: 18px; height: 18px; color: inherit; }
.fc-pet-icon::before {
  content: ''; position: absolute;
  width: 14px; height: 12px; border-radius: 50%;
  background: currentColor; opacity: .55;
  top: 0; left: 50%; transform: translateX(-50%);
}
.fc-pet-icon::after {
  content: ''; position: absolute;
  width: 0; height: 0;
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  top: -1px;
}
.fc-pet-icon.cat::after {
  border-bottom: 7px solid currentColor;
  left: 1px; opacity: .5;
  box-shadow: 7px 0 0 0 currentColor;
}
.fc-pet-icon.dog::after {
  border-bottom: 6px solid currentColor;
  left: 2px; opacity: .45;
  box-shadow: 6px 0 0 0 currentColor;
  border-radius: 0 0 2px 2px;
}

/* 品种色变体 */
.fc-avatar.pet.cat-orange { color: #D4956A; background: linear-gradient(135deg, rgba(212,149,106,.14), rgba(212,149,106,.04)); }
.fc-avatar.pet.cat-black  { color: #8A8A8A; background: linear-gradient(135deg, rgba(120,120,120,.12), rgba(120,120,120,.03)); }
.fc-avatar.pet.cat-white  { color: #C9B99A; background: linear-gradient(135deg, rgba(200,185,155,.12), rgba(200,185,155,.03)); }
.fc-avatar.pet.dog-gold   { color: #C9A96E; background: linear-gradient(135deg, rgba(201,169,110,.14), rgba(201,169,110,.04)); }
.fc-avatar.pet.dog-black  { color: #7A7A7A; background: linear-gradient(135deg, rgba(100,100,100,.12), rgba(100,100,100,.03)); }
.fc-avatar.pet.dog-brown  { color: #A0846A; background: linear-gradient(135deg, rgba(160,132,106,.14), rgba(160,132,106,.04)); }

/* 列表 staggered 入场 */
@keyframes listItemIn {
  from { opacity: 0; transform: translateX(-6px); }
  to   { opacity: 1; transform: translateX(0); }
}
.fc-record {
  animation: listItemIn .35s ease forwards;
  opacity: 0;
}
.fc-record:nth-child(1) { animation-delay: .05s; }
.fc-record:nth-child(2) { animation-delay: .10s; }
.fc-record:nth-child(3) { animation-delay: .15s; }
.fc-record:nth-child(4) { animation-delay: .20s; }
.fc-record:nth-child(5) { animation-delay: .25s; }
.fc-record:nth-child(6) { animation-delay: .30s; }
.fc-record:nth-child(7) { animation-delay: .35s; }
.fc-record:nth-child(8) { animation-delay: .40s; }
.fc-info { flex: 1; min-width: 0; }
.fc-name { font-size: 16px; font-weight: 600; color: #29302B; display: block; }
.fc-meta { font-size: 11px; color: #969D92; display: block; margin-top: 2px; }
.fc-stats { text-align: right; flex-shrink: 0; margin-right: 4px; }
.fcs-count { font-size: 12px; color: #717C73; display: block; }
.fcs-attention { font-size: 11px; color: #969D92; display: block; margin-top: 2px; }
.fcs-attention.has { color: #9B7A45; }
.fcs-attention.ok { color: #527F68; }
.fc-arrow { font-size: 11px; color: #969D92; white-space: nowrap; }
.fc-arrow.open { color: #9B7A45; }

/* 宠物提醒 */
.fc-pet-reminders { display: flex; gap: 6px; margin-top: 10px; flex-wrap: wrap; }
.fpr-item { font-size: 10px; padding: 3px 8px; border-radius: 6px; }
.fpr-item.urgent { background: rgba(155,122,69,.08); color: #9B7A45; }
.fpr-item.expired { background: rgba(185,95,87,.08); color: #B95F57; }

/* ===== 资料记录 ===== */
.fc-body {
  overflow: hidden;
  transition: max-height .35s ease, opacity .3s ease, margin .35s ease, padding .35s ease;
}
.fc-collapsed {
  max-height: 0; opacity: 0;
  margin-top: 0; padding-top: 0;
  border-top: none;
}
.fc-expanded {
  max-height: 3000px; opacity: 1;
  margin-top: 14px; padding-top: 14px;
  border-top: 1px solid var(--border);
}
.fc-empty { text-align: center; padding: 12px 0; font-size: 12px; color: #969D92; }
/* 左滑容器 */
.swipe-wrap {
  position: relative; overflow: hidden; margin-bottom: 14px;
  border-radius: 14px;
}
.swipe-delete {
  position: absolute; right: 0; top: 0; bottom: 0;
  width: 72px; display: flex; align-items: center; justify-content: center;
  background: var(--red); color: #FFFCF7; font-size: 13px; font-weight: 600;
  border-radius: 0 14px 14px 0; z-index: 0;
}

.fc-record {
  background: #F8F4EC; border-radius: 14px; padding: 16px 16px 14px;
  margin-bottom: 0; border: none; position: relative; z-index: 1;
  box-shadow: 0 1px 3px rgba(113,124,115,.04);
  transition: transform .25s cubic-bezier(.25,.8,.25,1.2);
}
.fc-record.swiped {
  transform: translateX(-72px);
  border-radius: 14px 0 0 14px;
}
.fc-record.expired { box-shadow: 0 1px 3px rgba(185,95,87,.06), 0 0 0 1px rgba(185,95,87,.1); }
.fc-record.soon { box-shadow: 0 1px 3px rgba(155,122,69,.06), 0 0 0 1px rgba(155,122,69,.1); }

.fcr-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 10px; }
.fcr-title-wrap { flex: 1; min-width: 0; }
.fcr-title {
  font-size: 16px; font-weight: 700; color: #29302B; display: block;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.fcr-subtitle { font-size: 11px; color: #969D92; display: block; margin-top: 6px; }
.fcr-status { text-align: right; flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
.fcr-days { font-size: 13px; font-weight: 700; color: #717C73; white-space: nowrap; }
.fcr-days.gold { color: #9B7A45; }
.fcr-days.red { color: #B95F57; }
.fcr-verify { font-size: 10px; color: #527F68; }
.fcr-verify.warn { color: #B95F57; }

.fcr-summary {
  font-size: 13px; color: #48534B; display: block; line-height: 1.55;
  margin-top: 8px; padding-top: 10px; border-top: 1px solid rgba(225,215,199,.5);
}
.fcr-boundary { font-size: 12px; color: #717C73; display: block; line-height: 1.5; margin-top: 6px; }

.fcr-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-top: 9px;
}
.fcr-field {
  min-height: 44px; background: rgba(255,252,246,.8); border-radius: 10px;
  padding: 8px 10px; display: flex; flex-direction: column; justify-content: center;
  border: 1px solid rgba(225,215,199,.4);
}
.fcr-field.missing { background: rgba(255,252,246,.4); border-color: rgba(225,215,199,.2); }
.fcr-field.reference { background: rgba(82,127,150,.06); border: 1px dashed rgba(82,127,150,.16); }
.fcr-field-label { font-size: 10px; color: #969D92; display: block; margin-bottom: 4px; }
.fcr-field-value { font-size: 14px; color: #29302B; line-height: 1.25; word-break: break-all; }
.fcr-field.missing .fcr-field-value { color: #B95F57; font-style: italic; }
.fcr-field-source { font-size: 9px; color: #527F96; margin-top: 3px; }
.fcr-match-note { font-size: 10px; color: #527F96; display: block; margin-top: 6px; }

.fcr-review { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin-top: 12px; }
.fcr-review-label { font-size: 11px; color: #969D92; flex-shrink: 0; }
.fcr-review-tag {
  font-size: 11px; color: #527F96; background: rgba(82,127,150,.08);
  border-radius: 6px; padding: 3px 8px;
}

/* ===== 环形进度 ===== */
.fcr-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 14px; }
.fcr-complete-group { display: flex; align-items: center; gap: 8px; }
.ring-progress {
  width: 36px; height: 36px; flex-shrink: 0;
  border-radius: 50%;
  background: conic-gradient(
    #9B7A45 var(--ring-pct),
    #E1D7C7 var(--ring-pct)
  );
  mask: radial-gradient(transparent 60%, black 61%);
  -webkit-mask: radial-gradient(transparent 60%, black 61%);
  position: relative;
}
.ring-inner {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; color: #9B7A45;
}
.fcr-cost { font-size: 11px; color: #969D92; }

.fcr-actions {
  display: flex; gap: 18px; margin-top: 12px; padding-top: 11px;
  border-top: 1px solid rgba(225,215,199,.5);
}
.fcr-check { font-size: 13px; color: #9B7A45; }
.fcr-del { font-size: 13px; color: #969D92; }

/* 档案底部 */
.fc-footer { display: flex; gap: 6px; margin-top: 10px; }
.add-bar { margin-top: 12px; }
.add-bar .btn { width: 100%; }

/* ===== 空状态：档案夹+纸页 ===== */
.empty-state { text-align: center; padding: 50px 16px; }
.empty-illustration { width: 90px; height: 72px; margin: 0 auto 20px; position: relative; }

/* 飘落的纸页 */
.ei-paper {
  position: absolute;
  background: var(--card);
  border-radius: 3px;
  box-shadow: var(--shadow-1);
}
@keyframes paperFloat {
  0%, 100% { transform: translateY(0) rotate(-8deg); }
  50% { transform: translateY(-6px) rotate(-6deg); }
}
@keyframes paperFloat2 {
  0%, 100% { transform: translateY(0) rotate(6deg); }
  50% { transform: translateY(-5px) rotate(8deg); }
}
@keyframes paperFloat3 {
  0%, 100% { transform: translateY(0) rotate(-3deg); }
  50% { transform: translateY(-4px) rotate(-1deg); }
}
.ei-paper.p1 {
  width: 32px; height: 40px; left: 8px; top: 12px;
  transform: rotate(-8deg);
  background: linear-gradient(160deg, var(--card) 0%, var(--bg-warm) 100%);
  animation: paperFloat 3.5s ease-in-out infinite;
}
.ei-paper.p2 {
  width: 28px; height: 36px; right: 10px; top: 8px;
  transform: rotate(6deg);
  background: linear-gradient(200deg, var(--card) 0%, var(--bg-warm) 100%);
  animation: paperFloat2 3.8s ease-in-out infinite .4s;
}
.ei-paper.p3 {
  width: 24px; height: 32px; left: 14px; bottom: 12px;
  transform: rotate(-3deg);
  background: linear-gradient(180deg, var(--card) 0%, var(--bg-warm) 100%);
  animation: paperFloat3 4.1s ease-in-out infinite .8s;
}

/* 档案夹主体 */
.ei-folder {
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 48px; height: 52px;
  background: linear-gradient(180deg, var(--gold-bg) 0%, rgba(142,107,62,.02) 100%);
  border-radius: 4px 4px 8px 8px;
  box-shadow: var(--shadow-1);
  border: 1.5px solid var(--gold-border);
  z-index: 1;
}
.ei-folder::before {
  content: ''; position: absolute; top: -6px; left: 4px;
  width: 18px; height: 7px;
  background: rgba(142,107,62,.1);
  border-radius: 3px 3px 0 0;
  border: 1.5px solid var(--gold-border);
  border-bottom: none;
}

/* 标签贴 */
.ei-label {
  position: absolute; right: -2px; top: 14px;
  width: 22px; height: 8px;
  background: rgba(90,138,110,.18);
  border-radius: 1px 2px 2px 1px;
  z-index: 2;
  transform: rotate(2deg);
}
.ei-label::after {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px;
  background: rgba(90,138,110,.08);
}

/* 皮筋绑带 */
.ei-band {
  position: absolute; left: 50%; top: 2px;
  transform: translateX(-50%);
  width: 52px; height: 4px;
  background: rgba(192,107,96,.12);
  border-radius: 2px;
  z-index: 0;
}

/* 氛围粒子 */
.ei-particle {
  position: absolute; width: 3px; height: 3px;
  background: rgba(142,107,62,.18);
  border-radius: 50%;
  animation: floatUp 3s ease-in-out infinite;
}
.ei-particle.p1 { left: 2px; top: 30px; animation-delay: 0s; width: 2px; height: 2px; }
.ei-particle.p2 { right: 4px; top: 10px; animation-delay: .7s; }
.ei-particle.p3 { left: 6px; bottom: 8px; animation-delay: 1.5s; }
@keyframes floatUp {
  0%, 100% { transform: translateY(0); opacity: .4; }
  50% { transform: translateY(-8px); opacity: .85; }
}

.empty-text { font-size: 16px; font-weight: 600; color: var(--text-primary); display: block; }
.empty-hint { font-size: 12px; color: var(--text-light); display: block; margin-top: 6px; }

/* ===== 按钮 ===== */
.btn {
  padding: 8px 16px; border-radius: 12px; border: none;
  background: #F2EBDD; color: #48534B; font-size: 13px; line-height: 1.4;
  box-shadow: 0 1px 3px rgba(113,124,115,.05);
  transition: transform .15s ease;
}
.btn:active { transform: scale(.97); }
.btn-gold {
  background: #9B7A45; color: #F8F4EC; font-weight: 600;
  box-shadow: 0 2px 8px rgba(155,122,69,.18);
}
.btn-sm { padding: 6px 10px; font-size: 11px; }

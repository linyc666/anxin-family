/* pages/mine/mine.wxss */
.container { padding: 16px 14px 100px; }
.bottom-space { height: 20px; }

/* 数据安全状态条 */
.safety-bar { display: flex; gap: 0; background: #FFFCF6; border: 1px solid #E1D7C7; border-radius: 12px; margin-bottom: 16px; overflow: hidden; }
.sb-item { flex: 1; display: flex; align-items: center; justify-content: center; gap: 6px; padding: 10px 6px; border-right: 1px solid #E1D7C7; }
.sb-item:last-child { border-right: none; }
.sb-dot { width: 6px; height: 6px; border-radius: 3px; flex-shrink: 0; }
.sb-dot.green { background: #527F68; }
.sb-dot.gray { background: #C4B99A; }
.sb-item text { font-size: 11px; color: #717C73; }

/* 会员状?*/
.member-card { display: flex; justify-content: space-between; align-items: center; background: #FFFCF6; border: 1px solid #E1D7C7; border-radius: 12px; padding: 14px; margin-bottom: 16px; }
.mc-plan { font-size: 15px; font-weight: 700; color: #9B7A45; display: block; }
.mc-usage { font-size: 11px; color: #969D92; display: block; margin-top: 3px; }
.mc-action { font-size: 13px; color: #9B7A45; font-weight: 600; }

/* 菜单?*/
.menu-group { margin-bottom: 14px; }
.menu-item { display: flex; align-items: center; gap: 10px; background: #FFFCF6; border: 1px solid #E1D7C7; border-radius: 10px; padding: 13px 14px; margin-bottom: 5px; }
.mi-label { font-size: 14px; color: #29302B; font-weight: 500; min-width: 70px; }
.mi-hint { flex: 1; font-size: 11px; color: #969D92; }
.mi-arrow { font-size: 16px; color: #E1D7C7; }

/* 反馈 */
.feedback-box { background: #FFFCF6; border: 1px solid #E1D7C7; border-radius: 12px; padding: 14px; margin-top: 6px; }
.fb-title { font-size: 14px; font-weight: 600; color: #29302B; display: block; margin-bottom: 8px; }
.fb-textarea { width: 100%; height: 72px; background: #F8F4EC; color: #48534B; border: 1px solid #E1D7C7; border-radius: 8px; padding: 10px; font-size: 12px; box-sizing: border-box; }
.fb-row { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
.fb-count { font-size: 11px; color: #969D92; }

/* 主题 */
.theme-section { margin: 0 0 14px; }
.theme-label { font-size: 11px; color: #969D92; font-weight: 600; display: block; margin-bottom: 8px; padding-left: 4px; }
.theme-row { display: flex; gap: 12px; }
.theme-dot { width: 36px; height: 36px; border-radius: 18px; display: flex; align-items: center; justify-content: center; border: 2px solid transparent; }
.theme-dot.active { border-color: #29302B; }
.theme-check { font-size: 14px; color: #F8F4EC; font-weight: 700; }

/* 按钮 */
.btn { padding: 7px 14px; border-radius: 10px; border: 1px solid #E1D7C7; background: #F2EBDD; color: #48534B; font-size: 12px; }
.btn-gold { background: #9B7A45; color: #F8F4EC; border-color: #9B7A45; font-weight: 600; }
.btn-sm { padding: 5px 10px; font-size: 11px; }

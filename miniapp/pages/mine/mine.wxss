/* pages/mine/mine.wxss */
.container { padding: 16px 14px 100px; }
.bottom-space { height: 20px; }

/* 数据安全状态条 */
.safety-bar {
  display: flex; gap: 0; background: #FFFCF6; border-radius: 14px;
  margin-bottom: 16px; overflow: hidden; border: none;
  box-shadow: 0 1px 3px rgba(113,124,115,.05), 0 2px 8px rgba(113,124,115,.03);
}
.sb-item {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 6px; padding: 12px 6px; border-right: 1px solid rgba(225,215,199,.5);
}
.sb-item:last-child { border-right: none; }
.sb-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.sb-dot.green { background: #527F68; box-shadow: 0 0 4px rgba(82,127,104,.25); }
.sb-dot.gray { background: #C4B99A; }
.sb-item text { font-size: 11px; color: #717C73; }

/* 会员状态卡 */
.member-card {
  display: flex; justify-content: space-between; align-items: center;
  border-radius: 14px; padding: 16px; margin-bottom: 16px; border: none;
  box-shadow: 0 1px 3px rgba(113,124,115,.05), 0 2px 8px rgba(113,124,115,.03);
  background: #FFFCF6;
  transition: box-shadow .2s ease;
}
.member-card:active { box-shadow: 0 0 2px rgba(113,124,115,.03); }
.mc-plan { font-size: 15px; font-weight: 700; color: #9B7A45; display: block; }
.mc-usage { font-size: 11px; color: #969D92; display: block; margin-top: 3px; }
.mc-action { font-size: 13px; color: #9B7A45; font-weight: 600; }

/* 菜单组 */
.menu-group { margin-bottom: 14px; }
.menu-item {
  display: flex; align-items: center; gap: 10px;
  background: #FFFCF6; border-radius: 12px; padding: 14px 16px;
  margin-bottom: 5px; border: none;
  box-shadow: 0 1px 3px rgba(113,124,115,.04);
  transition: box-shadow .15s ease;
}
.menu-item:active { box-shadow: 0 0 2px rgba(113,124,115,.02); }
.mi-label { font-size: 14px; color: #29302B; font-weight: 500; min-width: 70px; }
.mi-hint { flex: 1; font-size: 11px; color: #969D92; }
.mi-arrow { font-size: 16px; color: #C4B99A; }

/* 反馈 */
.feedback-box {
  background: #FFFCF6; border-radius: 14px; padding: 16px; margin-top: 6px;
  border: none;
  box-shadow: 0 1px 3px rgba(113,124,115,.04);
}
.fb-title { font-size: 14px; font-weight: 600; color: #29302B; display: block; margin-bottom: 8px; }
.fb-textarea {
  width: 100%; height: 72px; background: #F8F4EC; color: #48534B;
  border: 1px solid #E1D7C7; border-radius: 10px; padding: 10px;
  font-size: 12px; box-sizing: border-box;
}
.fb-row { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
.fb-count { font-size: 11px; color: #969D92; }

/* 主题 */
.theme-section { margin: 0 0 14px; }
.theme-label { font-size: 11px; color: #969D92; font-weight: 600; display: block; margin-bottom: 8px; padding-left: 4px; }
.theme-row { display: flex; gap: 12px; }
.theme-dot {
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 2px solid transparent; transition: border-color .2s ease;
}
.theme-dot.active { border-color: #29302B; }
.theme-check { font-size: 14px; color: #F8F4EC; font-weight: 700; }

/* 按钮 */
.btn {
  padding: 7px 14px; border-radius: 10px; border: none;
  background: #F2EBDD; color: #48534B; font-size: 12px;
  box-shadow: 0 1px 3px rgba(113,124,115,.04);
  transition: transform .15s ease;
}
.btn:active { transform: scale(.97); }
.btn-gold {
  background: #9B7A45; color: #F8F4EC; font-weight: 600;
  box-shadow: 0 2px 6px rgba(155,122,69,.16);
}
.btn-sm { padding: 5px 10px; font-size: 11px; }

/* ===== 深色主题覆盖 ===== */
.theme-dark .safety-bar { background: var(--card); box-shadow: var(--shadow-1); }
.theme-dark .member-card { background: var(--card); box-shadow: var(--shadow-1); }
.theme-dark .menu-item { background: var(--card); box-shadow: var(--shadow-1); }
.theme-dark .feedback-box { background: var(--card); box-shadow: var(--shadow-1); }
.theme-dark .fb-textarea { background: var(--bg); color: var(--text-body); border-color: var(--border); }
.theme-dark .btn { background: var(--bg-warm); color: var(--text-body); }
.theme-dark .btn-gold { background: var(--gold); color: #FFFCF7; }
.theme-dark .sb-item text { color: var(--text-muted); }
.theme-dark .mi-label { color: var(--text-primary); }
.theme-dark .mi-hint { color: var(--text-light); }
.theme-dark .fb-title { color: var(--text-primary); }
.theme-dark .fb-count { color: var(--text-light); }

<!--pages/checklist/checklist.wxml - 资料核对清单-->
<view class="container">
  <!-- 标题 -->
  <view class="cl-header">
    <text class="cl-title">{{ recordName }}</text>
    <text class="cl-sub">资料核对清单 · 仅供整理参考</text>
  </view>

  <!-- 完整度 -->
  <view class="cl-completeness">
    <view class="clc-bar-bg">
      <view class="clc-bar-fill" style="width:{{ completeness.percent }}%"></view>
    </view>
    <text class="clc-text">资料完整度 {{ completeness.filled }}/{{ completeness.total }}</text>
  </view>

  <!-- 到期状态 -->
  <view class="cl-card">
    <view class="cl-card-title">
      <text>到期状态</text>
    </view>
    <text class="cl-expiry {{ expiryStatus.cls }}">{{ expiryStatus.text }}</text>
  </view>

  <!-- 年度支出 -->
  <view class="cl-card">
    <view class="cl-card-title">
      <text>年度支出</text>
    </view>
    <text class="cl-spend {{ annualSpending.cls }}">{{ annualSpending.text }}</text>
  </view>

  <!-- 已填写字段 -->
  <view class="cl-card">
    <view class="cl-card-title">
      <text>已填写</text>
      <text class="cl-card-count ok">{{ filledFields.length }}</text>
    </view>
    <view class="cl-field ok" wx:for="{{ filledFields }}" wx:key="label">
      <text class="clf-label">{{ item.label }}</text>
      <text class="clf-value">{{ item.value }}</text>
    </view>
    <view class="cl-empty" wx:if="{{ filledFields.length === 0 }}">
      <text>暂无已填写字段</text>
    </view>
  </view>

  <!-- 待补充字段 -->
  <view class="cl-card cl-missing">
    <view class="cl-card-title">
      <text>待补充</text>
      <text class="cl-card-count warn" wx:if="{{ missingFields.length > 0 }}">{{ missingFields.length }}</text>
    </view>
    <view class="cl-field missing" wx:for="{{ missingFields }}" wx:key="label">
      <text class="clf-label">{{ item.label }}</text>
      <text class="clf-hint">{{ item.hint }}</text>
    </view>
    <view class="cl-done" wx:if="{{ missingFields.length === 0 }}">
      <text>全部字段已填写</text>
    </view>
  </view>

  <!-- 联系前可准备的资料 -->
  <view class="cl-card cl-prep">
    <view class="cl-card-title">
      <text>联系前可准备</text>
    </view>
    <view class="cl-prep-item" wx:for="{{ preConsultList }}" wx:key="*this">
      <text class="clp-num">{{ index + 1 }}</text>
      <text class="clp-text">{{ item }}</text>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="page-note">
    <text>本清单由系统根据已录入资料自动生成，仅供整理参考。</text>
  </view>
</view>

/* pages/policy-detail/policy-detail.wxss */
.container { padding: 20px 16px 120px; }

/* 头部 */
.pd-header {
  margin-bottom: 20px;
  padding: 20px;
  background: #FFFCF6; border-radius: 16px;
  box-shadow: 0 1px 3px rgba(113,124,115,.05), 0 4px 12px rgba(113,124,115,.04);
}
.pd-name { font-size: 22px; font-weight: 700; color: #29302B; display: block; }
.pd-status-row { display: flex; align-items: center; gap: 10px; margin-top: 8px; }
.pd-member { font-size: 13px; color: #969D92; }
.pd-verify-tag { font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 6px; }
.pd-verify-tag.warn { color: #B95F57; background: rgba(185,95,87,.08); }
.pd-verify-tag.ok { color: #527F68; background: rgba(82,127,104,.08); }

/* 类目说明 */
.pd-profile { margin-bottom: 14px; }
.pdp-label { font-size: 12px; font-weight: 700; color: #9B7A45; display: block; }
.pdp-summary { font-size: 13px; color: #48534B; line-height: 1.55; display: block; margin-top: 4px; }

/* 详情摘要卡 */
.pd-detail-card {
  background: #FFFCF6; border-radius: 14px; padding: 18px; margin-bottom: 10px; border: none;
  box-shadow: 0 1px 3px rgba(113,124,115,.05), 0 2px 8px rgba(113,124,115,.03);
}
.pdd-summary { margin-bottom: 14px; }
.pdd-summary-text { font-size: 16px; font-weight: 600; color: #29302B; line-height: 1.5; display: block; }
.pdd-section-label {
  font-size: 11px; font-weight: 600; color: #969D92; display: block;
  margin-bottom: 6px; margin-top: 12px;
}
.pdd-section-label:first-child { margin-top: 0; }
.pdd-boundary-list { display: flex; flex-direction: column; gap: 4px; }
.pdd-b-item { font-size: 13px; color: #48534B; line-height: 1.5; }
.pdd-meta-row { display: flex; flex-direction: column; gap: 3px; }
.pdd-meta-row text { font-size: 13px; color: #48534B; }
.pdd-review-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.pdd-rt {
  font-size: 11px; color: #527F96; background: rgba(82,127,150,.08);
  border-radius: 8px; padding: 3px 8px;
}

/* 字段列表 */
.pd-fields {
  display: flex; flex-direction: column; gap: 1px;
  background: rgba(225,215,199,.5); border-radius: 14px; overflow: hidden;
}
.pdf-item {
  display: flex; justify-content: space-between; align-items: flex-start;
  padding: 14px 16px; background: #FFFCF6; gap: 12px;
}
.pdf-item.full { flex-direction: column; gap: 6px; }
.pdf-label { font-size: 12px; color: #969D92; white-space: nowrap; min-width: 60px; }
.pdf-value { font-size: 14px; color: #48534B; text-align: right; line-height: 1.5; word-break: break-all; }
.pdf-item.full .pdf-value { text-align: left; }

/* 附件 */
.pd-attachment { margin-top: 16px; }
.pda-title { font-size: 13px; font-weight: 600; color: #717C73; display: block; margin-bottom: 8px; }
.pda-list { display: flex; flex-direction: column; gap: 6px; }
.pda-file {
  display: flex; align-items: center; gap: 10px; padding: 12px 14px;
  background: #FFFCF6; border-radius: 12px; border: none;
  box-shadow: 0 1px 3px rgba(113,124,115,.04);
}
.pda-file:active { box-shadow: 0 0 2px rgba(113,124,115,.02); }
.pda-icon { font-size: 14px; font-weight: 700; color: #9B7A45; min-width: 24px; text-align: center; }
.pda-info { flex: 1; min-width: 0; }
.pda-name {
  font-size: 13px; color: #48534B; display: block;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.pda-meta { font-size: 11px; color: #969D92; display: block; margin-top: 2px; }
.pda-arrow { font-size: 18px; color: #C4B99A; }

/* 空状态 */
.pd-empty { text-align: center; padding: 40px 0; }
.pd-empty text { font-size: 13px; color: #969D92; }

/* 底部操作栏 */
.pd-actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: 8px; padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: rgba(248,244,236,.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-top: 1px solid rgba(225,215,199,.5);
}
.pda-btn {
  flex: 1; height: 44px; border-radius: 12px; font-size: 14px;
  font-weight: 600; display: flex; align-items: center; justify-content: center;
  border: none; line-height: 1; transition: transform .15s ease;
}
.pda-btn::after { border: none; }
.pda-btn:active { transform: scale(.97); }
.pda-btn.edit { background: #9B7A45; color: #F8F4EC; box-shadow: 0 2px 8px rgba(155,122,69,.2); }
.pda-btn.check { background: rgba(82,127,150,.1); color: #527F96; }
.pda-btn.del { background: rgba(185,95,87,.06); color: #B95F57; }
.pda-btn.verify { background: rgba(82,127,104,.08); color: #527F68; }

/* 字段列表 staggered */
.pdf-item {
  animation: listItemIn .3s ease forwards; opacity: 0;
}
.pdf-item:nth-child(1) { animation-delay: .04s; }
.pdf-item:nth-child(2) { animation-delay: .08s; }
.pdf-item:nth-child(3) { animation-delay: .12s; }
.pdf-item:nth-child(4) { animation-delay: .16s; }
.pdf-item:nth-child(5) { animation-delay: .20s; }
.pdf-item:nth-child(6) { animation-delay: .24s; }
.pdf-item:nth-child(7) { animation-delay: .28s; }
.pdf-item:nth-child(8) { animation-delay: .32s; }
@keyframes listItemIn {
  from { opacity: 0; transform: translateX(-4px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* 附件列表 staggered */
.pda-file {
  animation: listItemIn .3s ease forwards; opacity: 0;
}
.pda-file:nth-child(1) { animation-delay: .05s; }
.pda-file:nth-child(2) { animation-delay: .10s; }
.pda-file:nth-child(3) { animation-delay: .15s; }
.pda-file:nth-child(4) { animation-delay: .20s; }
.pda-file:nth-child(5) { animation-delay: .25s; }

/* 深色主题 */
.theme-dark .pd-header { background: var(--card); box-shadow: var(--shadow-2); }
.theme-dark .pd-name { color: var(--text-primary); }
.theme-dark .pd-detail-card { background: var(--card); box-shadow: var(--shadow-1); }
.theme-dark .pd-fields { background: var(--border); }
.theme-dark .pdf-item { background: var(--card); }
.theme-dark .pda-file { background: var(--card); box-shadow: var(--shadow-1); }
.theme-dark .pd-actions { background: rgba(30,29,26,.92); border-top-color: var(--border); }
.theme-dark .pdd-summary-text { color: var(--text-primary); }
.theme-dark .pdf-value { color: var(--text-body); }
.theme-dark .pdf-label { color: var(--text-muted); }
.theme-dark .pda-name { color: var(--text-body); }

.container{padding:14px;padding-bottom:80px}
.form-section{background:#141923;border-radius:14px;padding:14px;margin-bottom:14px;border:1px solid #1e293b}
.section-title{font-size:15px;font-weight:700;color:#d4a853;display:block;margin-bottom:4px}
.section-hint{font-size:10px;color:#64748b;display:block;margin-bottom:12px}
.action-row{display:flex;gap:8px;align-items:center;margin-bottom:10px;flex-wrap:wrap}
.toggle-row{display:flex;align-items:center;gap:6px;font-size:11px;color:#94a3b8}
.toggle-label{font-size:11px;color:#94a3b8}
.toggle{width:32px;height:18px;border-radius:9px;background:#1e293b;border:1px solid #2a3344;transition:.2s}.toggle.on{background:rgba(212,168,83,.3);border-color:#d4a853}
.form-group{margin-bottom:10px}
.textarea{width:100%;min-height:140px;padding:10px 12px;border-radius:10px;border:1px solid #2a3344;background:#1a2332;color:#e2e8f0;font-size:13px;box-sizing:border-box}
.table-header{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #1e293b;margin-bottom:4px}
.th-name{font-size:11px;color:#64748b}.th-status{font-size:11px;color:#64748b}
.preview-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(30,41,59,.5)}
.preview-item.invalid{opacity:.5}
.pi-info{flex:1;min-width:0}
.pi-name{font-size:13px;color:#f1f5f9;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pi-meta{font-size:10px;color:#64748b;display:block}
.pi-issues{font-size:9px;color:#f59e0b;display:block;margin-top:2px}
.pi-status{font-size:12px;font-weight:700;flex-shrink:0}.pi-status.ok{color:#34d399}.pi-status.warn{color:#f59e0b}.pi-status.fail{color:#ef4444}
.preview-item.q-reject{opacity:.4}
/* 质量统计条 */
.quality-bar{display:flex;gap:6px;margin-bottom:10px}
.qb-item{flex:1;text-align:center;padding:8px 4px;border-radius:10px}
.qb-rec{background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.15)}
.qb-con{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.15)}
.qb-rej{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.15)}
.qb-num{font-size:18px;font-weight:700;display:block}.qb-rec .qb-num{color:#34d399}.qb-con .qb-num{color:#f59e0b}.qb-rej .qb-num{color:#f87171}
.qb-label{font-size:10px;color:#64748b}
/* 门槛切换 */
.quality-toggle{display:flex;gap:4px;align-items:center;font-size:11px;color:#94a3b8;margin-bottom:10px}
.qlevel{padding:3px 8px;border-radius:10px;font-size:10px;border:1px solid #2a3344;color:#64748b}
.qlevel.active{border-color:#d4a853;color:#d4a853;background:rgba(212,168,83,.1)}
.result-card{background:linear-gradient(135deg,rgba(16,185,129,.08),rgba(16,185,129,.02));border:1px solid rgba(16,185,129,.2);border-radius:14px;padding:16px;margin-top:8px}
.result-title{font-size:16px;font-weight:700;color:#34d399;display:block;margin-bottom:8px}
.result-stats{display:flex;flex-direction:column;gap:4px;margin-bottom:12px}
.rs-item{font-size:14px;color:#e2e8f0}
.btn{padding:7px 14px;border-radius:20px;border:1px solid #2a3344;background:#1a2332;color:#e2e8f0;font-size:13px;line-height:1.4}
.btn-gold{background:#d4a853;color:#0a0e17;border-color:#d4a853;font-weight:600}
.btn-blue{background:rgba(59,130,246,.15);border-color:#3b82f6;color:#93c5fd}
.btn-sm{padding:5px 10px;font-size:11px;border-radius:14px}

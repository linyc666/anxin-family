<view class="tab-bar {{ pageThemeClass }}" style="background-color:{{ tabBg }}; border-top-color:{{ tabBorder }}">
  <view class="tab-item {{ selected === index ? 'active' : '' }}"
        wx:for="{{ list }}"
        wx:key="index"
        data-index="{{ index }}"
        bindtap="switchTab">
    <text class="tab-icon">{{ item.icon }}</text>
    <text class="tab-text">{{ item.text }}</text>
  </view>
</view>
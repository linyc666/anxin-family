.tab-bar {
  display: flex;
  height: 56px;
  background: rgba(255,252,246,.94);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid rgba(225,215,199,.5);
  padding: 0 8px;
  padding-bottom: env(safe-area-inset-bottom);
  align-items: center;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 42px;
  border-radius: 12px;
  transition: all .2s ease;
  position: relative;
}

.tab-icon {
  font-size: 18px;
  display: block;
  line-height: 1;
}

.tab-text {
  font-size: 10px;
  font-weight: 500;
  color: #969D92;
  margin-top: 2px;
  transition: color .2s ease;
}

.tab-item.active {
  background: rgba(155,122,69,.06);
}

.tab-item.active .tab-text {
  color: #9B7A45;
  font-weight: 600;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}

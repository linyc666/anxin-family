.tab-bar {
  display: flex;
  height: 56px;
  background: rgba(255,252,246,.94);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid rgba(227,219,208,.5);
  padding: 0 8px;
  padding-bottom: env(safe-area-inset-bottom);
  align-items: center;
  transition: background .3s ease, border-color .3s ease;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 42px;
  border-radius: 12px;
  transition: all .2s ease;
}

.tab-icon {
  font-size: 18px;
  display: block;
  line-height: 1;
  transition: transform .2s ease;
}

.tab-text {
  font-size: 10px;
  font-weight: 500;
  color: #99A297;
  margin-top: 2px;
  transition: color .2s ease;
}

.tab-item.active {
  background: rgba(142,107,62,.06);
}

.tab-item.active .tab-text {
  color: #8E6B3E;
  font-weight: 600;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}

/* ===== 深色主题覆盖 ===== */
.theme-dark.tab-bar {
  background: rgba(42,40,36,.94);
  border-top-color: rgba(61,58,52,.5);
}

.theme-dark .tab-text {
  color: #706C63;
}

.theme-dark .tab-item.active {
  background: rgba(184,151,106,.1);
}

.theme-dark .tab-item.active .tab-text {
  color: #B8976A;
}

/* app.wxss ?暖白纸感（默认主题） */
page{background:#F8F4EC;color:#48534B;font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Microsoft YaHei',sans-serif;font-size:14px;line-height:1.6}
.container{padding:16px;padding-bottom:80px}
.header{padding:16px 0;border-bottom:1px solid #E1D7C7;margin-bottom:16px}
.title{font-size:20px;font-weight:700;color:#29302B}
.subtitle{font-size:13px;color:#717C73;margin-top:4px}

/* 统计卡片 */
.stats-grid{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px}
.stat-card{flex:1;min-width:140px;background:linear-gradient(145deg,#FFFCF6,#F2EBDD);border-radius:16px;padding:14px;text-align:center;border:1px solid #E1D7C7}
.stat-card .num{font-size:26px;font-weight:700;color:#9B7A45}
.stat-card .label{font-size:11px;color:#717C73;margin-top:4px}
.stat-card.alert{border-color:#B95F57}

/* 标签 */
.tag{display:inline-block;padding:2px 8px;border-radius:12px;font-size:11px;font-weight:600}
.tag-red{background:rgba(185,95,87,.15);color:#B95F57}
.tag-orange{background:rgba(155,122,69,.12);color:#9B7A45}
.tag-green{background:rgba(82,127,104,.12);color:#527F68}

/* 表单 */
.form-group{margin-bottom:16px}
.form-group .label{display:block;font-size:13px;color:#717C73;margin-bottom:6px}
.form-group .input,.form-group .textarea{width:100%;height:44px;padding:10px 12px;border-radius:10px;border:1px solid #E1D7C7;background:#F2EBDD;color:#48534B;font-size:14px;line-height:24px;box-sizing:border-box}
.form-group .textarea{height:auto;min-height:80px;line-height:1.6}
.form-group .picker{width:100%;height:44px;padding:10px 12px;border-radius:10px;border:1px solid #E1D7C7;background:#F2EBDD;color:#48534B;line-height:24px;box-sizing:border-box}
.form-row{display:flex;gap:10px}
.form-row .half{flex:1}

/* 按钮 */
.btn{padding:10px 20px;border-radius:12px;border:1px solid #E1D7C7;background:#F2EBDD;color:#48534B;font-size:14px;text-align:center}
.btn-gold{background:#9B7A45;color:#F8F4EC;border-color:#9B7A45;font-weight:600}
.btn-sm{padding:4px 10px;font-size:11px;border-radius:12px;border:1px solid #E1D7C7;background:#F2EBDD;color:#48534B;line-height:1.5}
.btn-red{background:rgba(185,95,87,.10);border-color:#B95F57;color:#B95F57}
.save-btn{width:100%;margin-top:20px;padding:14px;border-radius:12px;background:#9B7A45;color:#F8F4EC;font-weight:700;font-size:16px;border:none}

/* OCR */
.ocr-section{margin-bottom:16px}
.ocr-btn{width:100%;padding:14px;border-radius:12px;background:rgba(82,127,150,.10);border:1px solid rgba(82,127,150,.25);color:#527F96;font-size:15px}
.ocr-preview{width:100%;margin-top:8px;border-radius:10px}
.ocr-result-tag{background:rgba(82,127,104,.08);border:1px solid rgba(82,127,104,.15);border-radius:8px;padding:8px;margin-top:8px;font-size:12px;color:#527F68}

/* 自动补全 */
.ac-dropdown{background:#F2EBDD;border:1px solid #E1D7C7;border-radius:0 0 10px 10px;max-height:200px;overflow-y:auto}
.ac-item{padding:10px 12px;font-size:13px;color:#48534B;border-bottom:1px solid rgba(48,42,34,.5);display:flex;justify-content:space-between}
.ac-item:active{background:rgba(155,122,69,.08)}
.ac-name{flex:1}.ac-type{font-size:10px;color:#969D92}

/* 缺口卡片 */
.gap-card{background:#F2EBDD;border-radius:12px;padding:12px;margin-bottom:8px;border-left:3px solid #B95F57}
.gap-card.p1{border-left-color:#9B7A45}
.gap-card .g-title{font-weight:700;font-size:13px;color:#29302B}
.gap-card .g-desc{font-size:12px;color:#717C73;margin-top:4px}
.renewal-item{background:#F2EBDD;border-radius:10px;padding:10px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;font-size:12px}
.renewal-item .r-days{font-weight:700;font-size:16px}.r-days.red{color:#B95F57}.r-days.orange{color:#9B7A45}

/* 统一底部声明 */
.page-note{text-align:center;padding:16px 0 0;font-size:10px;color:#969D92;line-height:1.6}
.page-note text{display:block}
.page-note .note-link{color:#717C73;margin-top:4px}

/* 语义链接?*/
.link-blue{color:#527F96;font-size:11px}
.link-gold{color:#9B7A45;font-size:11px}
.link-gray{color:#969D92;font-size:11px}
.link-red{color:#B95F57;font-size:11px}

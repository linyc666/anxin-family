/* app.wxss — 安心家册 暖纸主题 v2 */

/* ===== CSS 色彩变量 ===== */
page {
  --gold: #8E6B3E;
  --gold-light: #A68654;
  --gold-bg: rgba(142,107,62,.06);
  --gold-bg-hover: rgba(142,107,62,.10);
  --gold-border: rgba(142,107,62,.18);
  --gold-shadow: rgba(142,107,62,.15);

  --bg: #F9F5EE;
  --bg-warm: #F3EDE2;
  --card: #FFFCF7;
  --card-hover: #FBF7F0;

  --text-primary: #2B2D29;
  --text-body: #4A5049;
  --text-muted: #737C72;
  --text-light: #99A297;

  --border: #E3DBD0;
  --border-light: rgba(227,219,208,.5);
  --border-soft: rgba(227,219,208,.3);

  --red: #C06B60;
  --red-bg: rgba(192,107,96,.08);
  --red-shadow: rgba(192,107,96,.12);

  --green: #5A8A6E;
  --green-bg: rgba(90,138,110,.08);
  --green-shadow: rgba(90,138,110,.1);

  --blue: #5A7F96;
  --blue-bg: rgba(90,127,150,.07);

  --shadow-1: 0 1px 3px rgba(74,80,73,.04), 0 2px 6px rgba(74,80,73,.03);
  --shadow-2: 0 2px 6px rgba(74,80,73,.05), 0 4px 14px rgba(74,80,73,.04);
  --shadow-3: 0 4px 12px rgba(74,80,73,.06), 0 8px 28px rgba(74,80,73,.05);
  --shadow-btn: 0 2px 6px rgba(142,107,62,.16);

  --radius-sm: 10px;
  --radius: 14px;
  --radius-lg: 18px;

  --ease-out: .2s ease;
  --ease-spring: .3s cubic-bezier(.34,1.56,.64,1);

  background:
    repeating-linear-gradient(
      0deg, transparent, transparent 2px,
      rgba(142,107,62,.006) 2px, rgba(142,107,62,.006) 4px
    ),
    radial-gradient(ellipse at 25% 40%, rgba(142,107,62,.025) 0%, transparent 55%),
    radial-gradient(ellipse at 75% 15%, rgba(90,127,150,.015) 0%, transparent 45%),
    var(--bg);
  color: var(--text-body);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 14px;
  line-height: 1.6;
}

/* ===== 卡片阴影体系 ===== */
.card-floating {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow-1);
  border: none;
}
.card-raised {
  background: var(--card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-2);
  border: none;
}
.card-elevated {
  background: var(--card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-3);
  border: none;
}
.card-transition {
  transition: transform var(--ease-out), box-shadow var(--ease-out);
}
.card-transition:active {
  transform: scale(.98);
  box-shadow: 0 0 2px rgba(74,80,73,.03);
}

/* ===== CSS 图标系统 ===== */
.icon {
  display: inline-block; position: relative;
  width: 20px; height: 20px; flex-shrink: 0;
  vertical-align: middle;
}
.icon-sm { width: 14px; height: 14px; }
.icon-lg { width: 26px; height: 26px; }

/* + 添加 */
.icon-plus::before, .icon-plus::after {
  content: ''; position: absolute;
  background: currentColor; border-radius: 1px;
}
.icon-plus::before {
  width: 100%; height: 2px; top: 50%; left: 0;
  transform: translateY(-50%);
}
.icon-plus::after {
  width: 2px; height: 100%; left: 50%; top: 0;
  transform: translateX(-50%);
}

/* 编辑 (铅笔简化) */
.icon-edit::before {
  content: ''; position: absolute;
  width: 10px; height: 4px; background: currentColor;
  border-radius: 1px;
  top: 14px; left: 4px;
  transform: rotate(-45deg);
}
.icon-edit::after {
  content: ''; position: absolute;
  width: 0; height: 0;
  border-left: 3px solid transparent;
  border-right: 3px solid transparent;
  border-bottom: 5px solid currentColor;
  top: 2px; left: 11px;
  transform: rotate(45deg);
}

/* 删除 (×) */
.icon-delete::before, .icon-delete::after {
  content: ''; position: absolute;
  width: 100%; height: 1.5px; background: currentColor;
  border-radius: 1px; top: 50%; left: 0;
}
.icon-delete::before { transform: rotate(45deg); }
.icon-delete::after  { transform: rotate(-45deg); }

/* 箭头 › */
.icon-chevron::before {
  content: ''; position: absolute;
  width: 6px; height: 6px;
  border-right: 1.5px solid currentColor;
  border-top: 1.5px solid currentColor;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%) rotate(45deg);
}

/* 展开 ▼ */
.icon-chevron-down::before {
  content: ''; position: absolute;
  width: 7px; height: 7px;
  border-right: 1.5px solid currentColor;
  border-bottom: 1.5px solid currentColor;
  top: 40%; left: 50%;
  transform: translate(-50%,-50%) rotate(45deg);
}

/* 核对 ✓ */
.icon-check::before {
  content: ''; position: absolute;
  width: 8px; height: 13px;
  border-right: 2px solid currentColor;
  border-bottom: 2px solid currentColor;
  top: 45%; left: 50%;
  transform: translate(-50%,-50%) rotate(42deg);
}

/* 房子 */
.icon-house::before {
  content: ''; position: absolute;
  width: 16px; height: 10px;
  border-left: 1.5px solid currentColor;
  border-right: 1.5px solid currentColor;
  border-bottom: 1.5px solid currentColor;
  border-radius: 0 0 2px 2px;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
}
.icon-house::after {
  content: ''; position: absolute;
  width: 0; height: 0;
  border-left: 10px solid transparent;
  border-right: 10px solid transparent;
  border-bottom: 8px solid currentColor;
  top: 0; left: 50%;
  transform: translateX(-50%);
}

/* 搜索/扫描 */
.icon-scan::before {
  content: ''; position: absolute;
  width: 12px; height: 12px;
  border: 1.5px solid currentColor;
  border-radius: 50%; top: 2px; left: 2px;
}
.icon-scan::after {
  content: ''; position: absolute;
  width: 4px; height: 1.5px; background: currentColor;
  border-radius: 1px;
  bottom: 3px; right: 1px; transform: rotate(-45deg);
}

/* 文档 */
.icon-doc::before {
  content: ''; position: absolute;
  width: 12px; height: 15px;
  border: 1.5px solid currentColor;
  border-radius: 2px; top: 1px; left: 3px;
}
.icon-doc::after {
  content: ''; position: absolute;
  width: 6px; height: 1px; background: currentColor;
  border-radius: 1px; top: 6px; left: 7px;
  box-shadow: 0 3px 0 currentColor, 0 6px 0 currentColor;
}

/* 人物 */
.icon-person::before {
  content: ''; position: absolute;
  width: 8px; height: 8px;
  border: 1.5px solid currentColor;
  border-radius: 50%; top: 1px; left: 50%;
  transform: translateX(-50%);
}
.icon-person::after {
  content: ''; position: absolute;
  width: 14px; height: 8px;
  border: 1.5px solid currentColor;
  border-radius: 8px 8px 0 0;
  border-bottom: none;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
}

/* 宠物爪印 */
.icon-paw::before {
  content: ''; position: absolute;
  width: 6px; height: 6px; background: currentColor;
  border-radius: 50%; top: 2px; left: 50%;
  transform: translateX(-50%);
  box-shadow:
    -5px 4px 0 -1px currentColor,
    5px 4px 0 -1px currentColor,
    -2px 8px 0 -1px currentColor,
    2px 8px 0 -1px currentColor;
}

/* ===== 入场动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes fadeInScale {
  from { opacity: 0; transform: scale(.94); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes softPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: .65; }
}

.entrance-item {
  opacity: 0;
  animation: fadeInUp .4s ease forwards;
}
.entrance-1 { animation-delay: .04s; }
.entrance-2 { animation-delay: .08s; }
.entrance-3 { animation-delay: .12s; }
.entrance-4 { animation-delay: .16s; }
.entrance-5 { animation-delay: .20s; }
.entrance-6 { animation-delay: .24s; }
.entrance-7 { animation-delay: .28s; }
.entrance-8 { animation-delay: .32s; }
.entrance-9 { animation-delay: .36s; }
.entrance-10 { animation-delay: .40s; }

.page-enter { animation: fadeIn .3s ease; }
.count-animate { animation: fadeInUp .35s ease; }

/* 脉冲点（时间轴提醒） */
.pulse-dot {
  animation: softPulse 2s ease-in-out infinite;
}

.container { padding: 16px; padding-bottom: 80px; }

/* ===== 统计卡片 ===== */
.stats-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
.stat-card {
  flex: 1; min-width: 140px; border-radius: var(--radius-lg);
  padding: 14px; text-align: center;
  background: var(--card);
  box-shadow: var(--shadow-1);
  border: none;
}
.stat-card .num { font-size: 26px; font-weight: 700; color: var(--gold); }
.stat-card .label { font-size: 11px; color: var(--text-muted); margin-top: 4px; }

/* ===== 标签 ===== */
.tag { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
.tag-red { background: var(--red-bg); color: var(--red); }
.tag-gold { background: var(--gold-bg); color: var(--gold); }
.tag-green { background: var(--green-bg); color: var(--green); }

/* ===== 表单 ===== */
.form-group { margin-bottom: 16px; }
.form-group .label { display: block; font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
.form-group .input, .form-group .textarea {
  width: 100%; height: 44px; padding: 10px 12px;
  border-radius: var(--radius-sm); border: 1px solid var(--border);
  background: var(--card); color: var(--text-body); font-size: 14px;
  line-height: 24px; box-sizing: border-box;
  box-shadow: 0 1px 2px rgba(74,80,73,.02);
}
.form-group .textarea { height: auto; min-height: 80px; line-height: 1.6; }
.form-group .picker {
  width: 100%; height: 44px; padding: 10px 12px;
  border-radius: var(--radius-sm); border: 1px solid var(--border);
  background: var(--card); color: var(--text-body); line-height: 24px; box-sizing: border-box;
}
.form-row { display: flex; gap: 10px; }
.form-row .half { flex: 1; }

/* ===== 按钮 ===== */
.btn {
  padding: 10px 20px; border-radius: 12px;
  background: var(--bg-warm); color: var(--text-body);
  font-size: 14px; text-align: center; border: none;
  box-shadow: 0 1px 2px rgba(74,80,73,.03);
  transition: transform .15s ease, box-shadow .15s ease;
}
.btn:active { transform: scale(.97); box-shadow: none; }
.btn-gold {
  background: var(--gold); color: #FFFCF7; font-weight: 600;
  box-shadow: var(--shadow-btn);
}
.btn-sm {
  padding: 5px 12px; font-size: 11px; border-radius: 10px;
  background: var(--bg-warm); color: var(--text-body); line-height: 1.5;
}
.btn-red { background: var(--red-bg); color: var(--red); }
.save-btn {
  width: 100%; margin-top: 20px; padding: 14px; border-radius: var(--radius);
  background: var(--gold); color: #FFFCF7; font-weight: 700; font-size: 16px;
  border: none; box-shadow: var(--shadow-btn); transition: transform .15s ease;
}
.save-btn:active { transform: scale(.97); }

/* ===== OCR ===== */
.ocr-section { margin-bottom: 16px; }
.ocr-btn {
  width: 100%; padding: 14px; border-radius: 12px;
  background: var(--blue-bg); border: none; color: var(--blue);
  font-size: 15px; box-shadow: 0 1px 3px rgba(90,127,150,.05);
}
.ocr-preview { width: 100%; margin-top: 8px; border-radius: var(--radius-sm); }
.ocr-result-tag {
  background: var(--green-bg); border-radius: 8px;
  padding: 8px; margin-top: 8px; font-size: 12px; color: var(--green);
}

/* ===== 自动补全 ===== */
.ac-dropdown {
  background: var(--card); border-radius: 0 0 10px 10px;
  max-height: 200px; overflow-y: auto; box-shadow: var(--shadow-3);
}
.ac-item {
  padding: 10px 12px; font-size: 13px; color: var(--text-body);
  border-bottom: 1px solid var(--border-soft); display: flex; justify-content: space-between;
}
.ac-item:active { background: var(--gold-bg); }
.ac-name { flex: 1; }
.ac-type { font-size: 10px; color: var(--text-light); }

/* ===== 统一底部声明 ===== */
.page-note { text-align: center; padding: 16px 0 0; font-size: 10px; color: var(--text-light); line-height: 1.6; }
.page-note text { display: block; }
.page-note .note-link { color: var(--text-muted); margin-top: 4px; }

/* ===== 语义链接 ===== */
.link-blue { color: var(--blue); font-size: 11px; }
.link-gold { color: var(--gold); font-size: 11px; }
.link-gray { color: var(--text-light); font-size: 11px; }
.link-red { color: var(--red); font-size: 11px; }
